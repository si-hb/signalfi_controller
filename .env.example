# Template for /opt/signalfi_controller/.env (signalfi-web app).
# Copy to .env and fill in real values.  Real .env is .gitignored.

# MQTT broker the signalfi-web app connects to
MQTT_HOST=apis.symphonyinteractive.ca
MQTT_PORT=1883
MQTT_USERNAME=signalfi-svc
MQTT_PASSWORD=
MQTT_TLS=false

# Mosquitto users (consumed by setup.sh to populate /root/config/pass.txt).
# Format: user:password pairs, whitespace-separated.  Quote passwords that
# contain shell metacharacters.
#   MQTT_USERS="symphony 'Si()%7274427'  signalfi-svc 'OtaService2024!'"
MQTT_USERS=
