# Template for /opt/signalfi_controller/.env on an air-gapped install.
# Copy to .env on the target CM4 and fill in real values before running
# setup.sh --airgap.  Real .env is .gitignored.

# ── Deployment mode ──────────────────────────────────────────────────────
# served = CM4 runs dnsmasq+chrony on the device LAN (recommended, isolated
#          install).
# byo    = Customer's existing DHCP/DNS/NTP handles the device LAN.  CM4 is
#          a pure application server with a reserved static IP.
AIRGAP_NETWORK_MODE=served

# ── Container runtime ────────────────────────────────────────────────────
# docker or podman.  Rootful required either way (privileged ports 53/67/123).
CONTAINER_RUNTIME=docker

# ── Network interfaces ───────────────────────────────────────────────────
# CM4 OS may name these end0/eth0/enx…  setup.sh verifies with `ip link show`.
AIRGAP_DEVICE_INTERFACE=eth0   # plugs into the PoE switch (device LAN)
AIRGAP_MGMT_INTERFACE=eth1     # plugs into operator workstation (optional)

# ── served-mode only ─────────────────────────────────────────────────────
# Static IP the CM4 claims on the device LAN.  Devices resolve
# apis.symphonyinteractive.ca to this address.
AIRGAP_HOST_IP=10.10.0.1

# Subnet in CIDR form — chrony uses this for its `allow` directive.
AIRGAP_SUBNET=10.10.0.0/24

# DHCP pool handed out to devices.  Start,end — dnsmasq syntax.
AIRGAP_DHCP_RANGE=10.10.0.100,10.10.0.250

# ── byo-mode only (informational) ────────────────────────────────────────
# Not consumed by setup.sh; used by deploy.sh airgap-build --package to
# pre-fill the customer README snippets.  Optional.
#SIGNALFI_SERVER_IP=10.20.30.40

# ── MQTT users (both modes) ──────────────────────────────────────────────
# Whitespace-separated user/password pairs, consumed by setup.sh to build
# /root/config/pass.txt (Mosquitto's hashed password file).  Quote passwords
# that contain shell metacharacters.
MQTT_USERS="symphony 'Si()%7274427'  signalfi-svc 'OtaService2024!'"
